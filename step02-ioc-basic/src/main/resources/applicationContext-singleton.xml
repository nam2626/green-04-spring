<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.springframework.org/schema/beans
        https://www.springframework.org/schema/beans/spring-beans.xsd">

   <!--
          singleton은 Spring의 기본 스코프입니다.
          컨테이너가 Bean 객체를 하나만 만들고, getBean()을 여러 번 호출해도 같은 객체를 돌려줍니다.
   -->
   <bean id="counterBean" class="singleton.CounterBean" scope="singleton"/>

   <!--
          prototype은 getBean()을 호출할 때마다 새로운 객체를 만들어 줍니다.
          매번 독립적인 상태가 필요한 객체를 설명할 때 사용하는 예제입니다.
   -->
   <bean id="temporaryBean" class="singleton.TemporaryBean" scope="prototype"/>

</beans>






