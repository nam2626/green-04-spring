<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd">

    <!--
    ====================================================================
    TODO [문제 2-4] component-scan을 추가하세요.
      Spring이 com.spring.problem02 패키지를 탐색해
      @Component/@Service/@Repository 어노테이션이 붙은 클래스를
      자동으로 Bean으로 등록하도록 설정합니다.

      힌트:
        <context:component-scan base-package="패키지명"/>
    ====================================================================
    -->
	<!--
		component-scan은 지정한 패키지에서 @Component, @Service, @Repository가 붙은
		클래스를 찾아 Spring Bean으로 자동 등록합니다.
		이 설정 덕분에 Java 클래스마다 XML <bean>을 직접 작성하지 않아도 됩니다.
	-->
	<context:component-scan base-package="com.spring.problem02"></context:component-scan>	
</beans>





