<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- 이 파일은 수정하지 않아도 됩니다. ProblemMain.java만 완성하세요. -->

    <!-- singleton (기본값 — scope 생략 가능) -->
    <bean id="counterBean"   class="com.spring.problem03.CounterBean" scope="singleton"/>

    <!-- prototype — getBean() 마다 새 인스턴스 생성 -->
    <bean id="temporaryBean" class="com.spring.problem03.TemporaryBean" scope="prototype"/>

</beans>
